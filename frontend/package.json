{
    "name": "frontend",
    "private": true,
    "version": "2.5.0",
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "electron": "electron .",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:build:win": "npm run build && electron-builder --win"
    },
    "build": {
        "appId": "com.deepseek.proxy-manager",
        "productName": "AI Proxy Manager",
        "directories": {
            "output": "release",
            "buildResources": "build"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "extraFiles": [
            {
                "from": "../dist/proxy-backend.exe",
                "to": "proxy-backend.exe"
            }
        ]
    },
    "dependencies": {
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.14.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@electron/remote": "^2.1.3",
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.2.1",
        "electron": "^42.0.0",
        "electron-builder": "^26.8.1",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^3.4.19",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "wait-on": "^9.0.5"
    }
}
